{
  "name": "food-twin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "next lint && tsc --noEmit",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "bun run --bun prisma/seed.ts",
    "db:seed:off": "bun run --bun prisma/seedOpenFoodFacts.ts",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "5.21.0-integration-25129.1",
    "@t3-oss/env-nextjs": "^0.10.1",
    "@tanstack/react-query": "^5.100.0",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "geist": "^1.7.0",
    "next": "^15.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/eslint": "^8.56.10",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.10",
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "prisma": "5.21.0-integration-25129.1",
    "csv-parse": "^5.6.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "ct3aMetadata": {
    "initVersion": "7.38.1"
  }
}
